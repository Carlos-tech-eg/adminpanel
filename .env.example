# Free port on your machine; match `frontend/vite.config.ts` proxy if you use `npm run dev:ui`
PORT=4010
MONGODB_URI=mongodb://127.0.0.1:27017/embassy_admin
# true = embedded Mongo (no install); false = real MongoDB at MONGODB_URI
USE_MEMORY_MONGO=false
JWT_SECRET=change-this-to-a-long-random-string-in-production
NODE_ENV=development

# --- Auth: real vs demo ---
# false = bcrypt passwords (production). true = any non-empty password for users without hash + demo seed users
MOCK_AUTH=false
# true = insert sample news, visas, registrations, appointments on first empty DB (development only)
# SEED_DEMO_CONTENT=false

# First boot only (empty users collection): create one Admin, then remove password from .env
# INITIAL_ADMIN_EMAIL=admin@your-embassy.gov
# INITIAL_ADMIN_PASSWORD=min8chars
# INITIAL_ADMIN_DISPLAY_NAME=Site Administrator

# --- Public embassy website (Next.js) ---
# If set, POST /api/public/contact and /api/public/registro require header: x-embassy-public-key: <same value>
# PUBLIC_FORM_SECRET=long-random-string
# Absolute URL of this API for /media-files in GET /api/public/news (optional)
# PUBLIC_ADMIN_BASE_URL=https://admin.your-domain.gov
