# Free port on your machine; match `frontend/vite.config.ts` proxy if you use `npm run dev:ui`
PORT=4010
# Either set full URI, OR (recommended on Vercel) use the split Atlas vars below — secrets stay separate; password is URL-encoded for you.
MONGODB_URI=mongodb://127.0.0.1:27017/embassy_admin
# MONGODB_ATLAS_USER=
# MONGODB_ATLAS_PASSWORD=
# MONGODB_ATLAS_HOST=cluster0.xxxxx.mongodb.net
# MONGODB_ATLAS_DB=embassy_admin
# MONGODB_ATLAS_APPNAME=Cluster0

# true = embedded Mongo (no install); false = real MongoDB (MONGODB_URI or MONGODB_ATLAS_*)
USE_MEMORY_MONGO=false
JWT_SECRET=change-this-to-a-long-random-string-in-production
NODE_ENV=development

# --- Auth: real vs demo ---
# false = bcrypt passwords (production). true = any non-empty password for users without hash + demo seed users
MOCK_AUTH=false
# true = insert sample news, visas & appointments on first empty DB — not consular rows (solo datos reales del formulario)
# SEED_DEMO_CONTENT=false

# First boot only (empty users collection): create one Admin, then remove password from .env
# INITIAL_ADMIN_EMAIL=admin@your-embassy.gov
# INITIAL_ADMIN_PASSWORD=min8chars
# INITIAL_ADMIN_DISPLAY_NAME=Site Administrator

# --- Public embassy website (Next.js) ---
# Vercel Production: REQUIRED. Sin esto, POST /api/consular-registration (y /api/public/*) responde 503.
# La web Next.js debe enviar la MISMA cadena en la cabecera x-embassy-public-key (variable PUBLIC_FORM_SECRET allí).
# If set, POST /api/public/contact and /api/public/registro require header: x-embassy-public-key: <same value>.
# In NODE_ENV=production this MUST be set (unless ALLOW_INSECURE_PUBLIC_POST=true, not recommended).
# PUBLIC_FORM_SECRET=long-random-string
# Alias por si hubo error de nombre en el dashboard (misma cadena):
# EMBASSY_PUBLIC_FORM_SECRET=long-random-string
# Absolute URL of this API for /media-files in GET /api/public/news (optional)
# PUBLIC_ADMIN_BASE_URL=https://admin.your-domain.gov

# --- HTTP hardening (production) ---
# Comma-separated browser origins allowed to call the API (admin URL + main website if browser calls API).
# If unset in production, CORS stays permissive and a warning is logged — set explicitly when you can.
# ALLOWED_ORIGINS=https://admin.your-domain.gov,https://www.your-domain.gov
# Extra origins for server-to-server or browser calls from the public Next.js site (comma-separated).
# PUBLIC_WEB_ORIGINS=https://www.your-domain.gov,https://your-app.vercel.app
# Or single site URL (no comma needed if only one):
# PUBLIC_SITE_URL=https://www.your-domain.gov
# Vercel: trust X-Forwarded-* from edge (default 1 hop)
# TRUST_PROXY_HOPS=1
# Login rate limit: max POST /api/auth/login per IP per 15 minutes (default 8)
# AUTH_LOGIN_MAX_PER_WINDOW=8
# MongoDB connection pool per serverless instance (keep small on Atlas M0/M2)
# MONGODB_MAX_POOL_SIZE=10
# NEVER in real production: bypass PUBLIC_FORM_SECRET requirement for POST /api/public/contact|registro
# ALLOW_INSECURE_PUBLIC_POST=false
